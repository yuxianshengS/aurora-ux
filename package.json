{
  "name": "aurora-ux",
  "version": "0.6.0",
  "description": "中后台 / 数据看板 UI 组件库 + 可视化搭建器. Dashboard-ready React components with a drag-and-drop page builder.",
  "type": "module",
  "main": "./dist/aurora-ui.cjs",
  "module": "./dist/aurora-ui.mjs",
  "types": "./dist/lib.d.ts",
  "sideEffects": [
    "**/*.css",
    "./dist/aurora-ui.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/aurora-ui.mjs",
      "require": "./dist/aurora-ui.cjs"
    },
    "./dist/aurora-ui.css": "./dist/aurora-ui.css",
    "./style.css": "./dist/aurora-ui.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "ui",
    "components",
    "dashboard",
    "admin",
    "low-code",
    "page-builder",
    "tailwind",
    "typescript"
  ],
  "author": "yuxianshengS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuxianshengS/aurora-ux.git"
  },
  "homepage": "https://yuxianshengS.github.io/aurora-ux/",
  "bugs": {
    "url": "https://github.com/yuxianshengS/aurora-ux/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "clean": "rm -rf dist",
    "build:lib": "pnpm clean && vite build --mode lib",
    "preview": "vite preview",
    "sync:icon": "node scripts/sync-iconfont.mjs",
    "prepublishOnly": "pnpm build:lib"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "echarts": ">=5.0.0",
    "echarts-gl": ">=2.0.0",
    "html2canvas": ">=1.0.0",
    "jspdf": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "echarts-gl": {
      "optional": true
    },
    "html2canvas": {
      "optional": true
    },
    "jspdf": {
      "optional": true
    }
  },
  "dependencies": {
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "echarts": "^5.6.0",
    "echarts-gl": "^2.0.9",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
